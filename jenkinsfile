pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking source code'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t myapp:latest ./app'
            }
        }

        stage('Test') {
            steps {
                sh ''' docker run  -p 3000:3000 myapp '''
                
                
            }
        }
        stage('Deploy') {
            steps {
                sh ''' curl http://localhost:3000 '''
                
                
                
                
            }
        }
    }
}