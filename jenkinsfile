pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking source code'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t myapp:latest ./app'
                sh 'node server.js'
            }
        }

        stage('Test') {
            steps {
                sh ''' docker run  -p 3000:3000 myapp 
                        curl http://localhost:3000'''
                
                
            }
        }
        stage('Deploy') {
            steps {
                sh ' echo "hi" '
                
                
                
                
            }
        }
    }
}