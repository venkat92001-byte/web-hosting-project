pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking source code'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t myapp:latest ./app'
            }
        }

        stage('Test') {
            steps {
                sh ''' docker run -i -p 3000:3000 myapp:latest  '''
                
                
            }
        }
        stage('Deploy') {
            steps {
                sh ''' docker stop app-container || true docker rm app-container || true docker run -d  --name myapp  -p 3000:3000 myapp:latest '''
                
                
                
                
            }
        }
    }
}