pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking source code'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t myapp:latest ./app'
            }
        }

        stage('Test') {
            steps {
                sh 'whoami'
                sh 'docker ps'
                sh 'docker images'
            }
        }
        stage('Deploy') {
            steps {
                sh '''
                docker stop myapp || true
                docker rm myapp || true
                docker run -d --name myapp -p 80:80 myapp:latest
                '''
            }
        }
    }
}