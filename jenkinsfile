pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking source code'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t myapp:latest ./app'
            }
        }

        stage('Test') {
            steps {
                sh ''' docker run -d --name test-container -p 3000:3000 myapp:latest sleep 10 curl http://localhost:3000 | grep "Hello from Jenkins CI/CD!" docker stop test-container docker rm test-container '''
                
                
            }
        }
        stage('Deploy') {
            steps {
                sh ''' docker stop app-container || true docker rm app-container || true docker run -d \ --name app-container \ -p 3000:3000 \ myapp:latest '''
                
                
                
                
            }
        }
    }
}