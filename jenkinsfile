pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking source code'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t node-app ./app'
                
            }
        }

        stage('Test') {
            steps {
                sh ' docker run -d --name node-app-container  -p 3000:3000 node-app'
                
                
                
            }
        }
        stage('Deploy') {
            steps {
                sh ' echo "hi" '
                
                
                
                
            }
        }
    }
}